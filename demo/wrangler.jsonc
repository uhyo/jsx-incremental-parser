{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "jsx-incremental-parser-demo",
  "compatibility_date": "2026-06-20",
  // Assets-only Worker: no `main` script, Cloudflare just serves the built SPA
  // from `./dist`. `single-page-application` rewrites unknown paths to
  // `index.html` so client-side routing / deep links don't 404.
  "assets": {
    "directory": "./dist",
    "not_found_handling": "single-page-application",
  },
}
